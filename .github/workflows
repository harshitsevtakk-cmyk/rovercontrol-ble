name: Generate Cloud APK

on:
  push:
    branches: [ "main" ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout repository
      uses: actions/checkout@v4

    - name: Set up JDK 17
      uses: actions/setup-java@v4
      with:
        java-version: '17'
        distribution: 'temurin'

    - name: Inject Gemini API Key
      run: |
        echo "GEMINI_API_KEY=${{ secrets.GEMINI_API_KEY }}" > .env
        echo "GEMINI_API_KEY=" > .env.example

    - name: Fix gradle config
      run: |
        if [ -f app/build.gradle.kts ]; then
          sed -i '/signingConfig = signingConfigs.getByName("debugConfig")/d' app/build.gradle.kts
        fi

    - name: Build Debug APK using System Gradle
      run: gradle assembleDebug

    - name: Upload APK Artifact
      uses: actions/upload-artifact@v4
      with:
        name: picoarm-app-apk
        path: app/build/outputs/apk/debug/app-debug.apk
